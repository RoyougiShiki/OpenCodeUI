* text=auto eol=lf

# Explicit overrides
*.sh text eol=lf
Caddyfile text eol=lf
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Binary files - do not normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar.gz binary
*.lock binary
